{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "rootDir": ".",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "common/src/**/*.ts",
    "container/src/**/*.ts",
    "serverless/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}